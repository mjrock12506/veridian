# Raw data (large; not committed)
data/raw/

# Derived data artifacts (regenerated by the pipeline)
data/processed/*.csv
data/*.db
data/*.sqlite
data/*.sqlite3

# Incremental-replay cursor (Phase 7 live pipeline; regenerated each run)
data/state/

# Generated risk digests (Phase 7 reports/alerts; regenerated each run)
reports/digests/

# Python envs / caches
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Secrets / config
.env

# Internal tooling config (not part of the published project)
CLAUDE.md
.claude/

# ML / experiment artifacts
mlruns/
models/artifacts/*.joblib
models/artifacts/*.pkl

# AI layer — local vector store (regenerated by `python -m ai.index_knowledge`)
ai/.chroma/
