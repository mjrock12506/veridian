# Veridian environment configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real secrets. This single file documents
# EVERY variable the project uses across the backend, pipeline, and (for
# reference) the frontend. Each component reads only the vars relevant to it.
# See docs/DEPLOYMENT.md for where each one is set when going live.

# =============================================================================
# Database / warehouse  (pipeline + API)
# =============================================================================
# Leave unset to use the default local SQLite file (data/veridian.db).
# In production, point at managed Postgres (Render/Supabase/Neon) — the same
# code path serves both; only this URL changes:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=sqlite:///data/veridian.db

# =============================================================================
# Backend API  (FastAPI — Render / HF Spaces)
# =============================================================================
# Comma-separated browser origins allowed by CORS. Set to your frontend URL(s).
# Defaults to the local Next.js dev server when unset.
# CORS_ORIGINS=http://localhost:3000,https://veridian.vercel.app
#
# PORT is injected by the host (Render/HF Spaces); no need to set it locally.
# PORT=8000

# =============================================================================
# AI copilot  (Phase 5 — optional; only used by the /ask endpoint)
# =============================================================================
# The copilot talks to the LLM through LiteLLM, so any provider works by setting
# LLM_MODEL to a `provider/model` string and supplying that provider's key.
GEMINI_API_KEY=

# Override the model without touching code. Examples:
#   gemini/gemini-2.5-flash        (default; Gemini free tier)
#   groq/llama-3.3-70b-versatile   (needs GROQ_API_KEY)
#   anthropic/claude-haiku-4-5     (needs ANTHROPIC_API_KEY)
#   ollama/llama3                  (local; no key needed)
# LLM_MODEL=gemini/gemini-2.5-flash

# Optional provider keys (only the one matching LLM_MODEL is used).
# GROQ_API_KEY=
# ANTHROPIC_API_KEY=

# Optional copilot tuning.
# LLM_TEMPERATURE=0.0
# LLM_MAX_TOKENS=700
# RAG_TOP_K=4

# =============================================================================
# Frontend  (Next.js — Vercel). Set these in web/.env.local or the Vercel UI.
# Listed here for completeness; the backend does NOT read them.
# =============================================================================
# Base URL of the deployed backend API.
# NEXT_PUBLIC_API_URL=https://veridian-api.onrender.com
#
# Supabase Auth (Phase 6C). Both are public (anon key is browser-safe). Leave
# unset to run the web app locally with auth disabled.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# =============================================================================
# Live pipeline reports/alerts  (Phase 7 — optional, for `pipeline.report --email`)
# =============================================================================
# Provider-agnostic SMTP. Works with Gmail, SendGrid, Mailgun, Amazon SES, etc.
# If SMTP_HOST / ALERT_EMAIL_FROM / ALERT_EMAIL_TO are unset, the email step is
# skipped and the digest is only saved to reports/digests/.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=
# SMTP_STARTTLS=true
# SMTP_SSL=false
# ALERT_EMAIL_FROM=veridian@example.com
# ALERT_EMAIL_TO=ops@example.com,oncall@example.com

# =============================================================================
# CI data acquisition  (Phase 7 live-pipeline workflow — repo secrets, not .env)
# =============================================================================
# The scheduled GitHub Action needs the raw Olist dataset. Provide ONE of:
#   OLIST_DATA_URL  : URL to a zip of the Olist CSVs (simplest), or
#   KAGGLE_USERNAME + KAGGLE_KEY : to pull olistbr/brazilian-ecommerce.
# Set these as GitHub repository secrets, not in this file.
# OLIST_DATA_URL=
# KAGGLE_USERNAME=
# KAGGLE_KEY=
