# Veridian environment configuration — copy to `.env` and fill in.
# `.env` is gitignored; never commit real secrets.

# --- Database (Phase 2 ETL target) ---
# Leave unset to use the default local SQLite file (data/veridian.db).
# To target Postgres (e.g. Supabase/Neon later), set a SQLAlchemy URL:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
# DATABASE_URL=sqlite:///data/veridian.db

# --- Anthropic API (Phase 5 AI layer — NOT used yet) ---
# ANTHROPIC_API_KEY=
