# Keep the build context (and image) small — but NOT models/artifacts/,
# which the API needs at runtime.
.git/
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
data/
notebooks/
docs/
web/
reports/
# ...but keep the one report file the dashboard drill-down reads at runtime.
!reports/shap_delay.json
# Keep the ai/ package (copilot + committed TF-IDF corpus) in the image, but
# drop the local vector-store cache (legacy, regenerated, never used at runtime).
ai/.chroma/
tests/
*.db
.env
.github/
