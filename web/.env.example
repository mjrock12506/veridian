# Veridian web app environment — copy to `.env.local` for local development.
# `.env.local` is gitignored; never commit real values.

# --- Backend API (Phase 4/6) ---
# Base URL of the Veridian FastAPI backend (uvicorn api.main:app).
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Supabase Auth (Phase 6C) ---
# From your Supabase project: Settings -> API.
# Both are PUBLIC (the anon key is safe to expose to the browser).
# Leave BOTH unset to run locally with authentication disabled — the app shows
# an "auth not configured" state instead of crashing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
